# PAI Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ============================================================================


# ============================================================================
# VOICE SERVER CONFIGURATION
# ============================================================================

# HTTP port for voice server API
PORT=8888

# TTS provider: chatterbox (local/free), elevenlabs (cloud/paid), none (disabled)
VOICE_PROVIDER=chatterbox

# Voice ID for Chatterbox local TTS (reference audio file name without extension)
CHATTERBOX_VOICE_ID=jessica


# ============================================================================
# ELEVENLABS (Optional - premium cloud voice synthesis alternative)
# Only needed if VOICE_PROVIDER=elevenlabs; default provider is chatterbox (local/free)
# ============================================================================

# Get your key from: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice name - browse voices at: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=Jessica

# Model options: eleven_multilingual_v2 (default), eleven_turbo_v2_5, eleven_flash_v2_5
# See: https://elevenlabs.io/docs/models#models-overview
# ELEVENLABS_MODEL=eleven_multilingual_v2


# ============================================================================
# RESEARCH AGENTS - API Keys
# ============================================================================

# Perplexity API (perplexity-researcher agent)
# Get your key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Gemini API (gemini-researcher agent)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API (for task runner Claude backend)
# Get your key from: https://console.anthropic.com/settings/keys
# Note: Claude Code itself uses its own authentication — this key is for
# the task_runner's local_claude_runner.sh backend only
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ============================================================================
# AI IMAGE/VIDEO GENERATION (Optional)
# ============================================================================

# OpenAI API (for GPT-Image-1, DALL-E, etc.)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Replicate API (for Flux, Stable Diffusion, etc.)
# Get your key from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here


# ============================================================================
# TRANSCRIPTION (whisper.cpp)
# ============================================================================

# Whisper model size: tiny, base, small, medium, large
# Larger models are more accurate but slower. "base" is the recommended default.
# Models are stored in: .agent/tools/whisper.cpp/models/
WHISPER_MODEL=base


# ============================================================================
# DISCORD BOT (Optional - for Discord remote control)
# ============================================================================

# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Server (guild) ID where the bot operates
DISCORD_GUILD_ID=your_guild_id_here

# Channel ID the bot listens on
DISCORD_CHANNEL_ID=your_channel_id_here

# Comma-separated list of Discord user IDs allowed to interact with the bot
DISCORD_ALLOWED_USER_IDS=your_user_id_here


# ============================================================================
# WEB SCRAPING (Optional)
# ============================================================================

# Bright Data API (for scraping sites with bot detection/CAPTCHAs)
# Get your key from: https://brightdata.com
BRIGHTDATA_API_KEY=your_brightdata_api_key_here


# ============================================================================
# TASK RUNNER - LLM Backend Configuration
# ============================================================================

# Ollama local LLM server
# Install from: https://ollama.ai
# Default endpoint for chat completions API
OLLAMA_URL=http://localhost:11434/v1/chat/completions

# Default models for each task runner backend
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-3-5-haiku-20241022
QWEN_MODEL=gpt-oss:latest
OLLAMA_MODEL=gpt-oss:latest


# ============================================================================
# PROJECT CONFIGURATION
# ============================================================================

# PAI installation root (set automatically by setup script)
# Only override if using a non-standard installation path
# PAI_DIR=/home/youruser/.claude

# PAI home directory (typically same as $HOME)
# PAI_HOME=/home/youruser


# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env file to git (it's in .gitignore)
# 2. Rotate API keys regularly
# 3. Use minimum required permissions for each API key
# 4. Keep .env file permissions restricted: chmod 600 .env
