#!/usr/bin/env bash
#
# Autonomous Task Executor
# Picks approved items from backlog, executes them, tracks results
# Only runs when no interactive session is active (heartbeat guard)
#
# Usage: pai-executor [--dry-run] [--timeout 30m|90m]

set -euo pipefail

PAI_DIR="${PAI_DIR:-${HOME}/.claude}"
LOG_FILE="${HOME}/Library/Logs/pai-executor.log"
MANAGE_BACKLOG="${HOME}/Projects/sam/.agent/scripts/manage-backlog.sh"
MEMORY_SERVICE_URL="${MEMORY_SERVICE_URL:-http://localhost:4242}"
DISCORD_WEBHOOK="${DISCORD_WEBHOOK:-}"
DRY_RUN="${1:---dry-run}"
TIMEOUT="${2:-30m}"

# Parse timeout to seconds
TIMEOUT_SECONDS=1800  # default 30m
case "$TIMEOUT" in
  30m) TIMEOUT_SECONDS=1800 ;;
  90m) TIMEOUT_SECONDS=5400 ;;
  *)   TIMEOUT_SECONDS=$((${TIMEOUT%m} * 60)) ;;
esac

# ---------------------------------------------------------------------------
# Logging and Notifications
# ---------------------------------------------------------------------------

log() {
  local level="$1"
  shift
  local msg="$*"
  local timestamp
  timestamp=$(date '+%Y-%m-%d %H:%M:%S')
  echo "[${timestamp}] [${level}] ${msg}" | tee -a "$LOG_FILE"
}

post_discord() {
  local message="$1"

  if [[ -z "$DISCORD_WEBHOOK" ]]; then
    # Try to read from .env
    if [[ -f "${PAI_DIR}/.env" ]]; then
      DISCORD_WEBHOOK=$(grep '^DISCORD.*WEBHOOK=' "${PAI_DIR}/.env" 2>/dev/null | cut -d'=' -f2- | tr -d '"' || echo "")
    fi
  fi

  if [[ -z "$DISCORD_WEBHOOK" ]]; then
    log "WARN" "Discord webhook not configured — skipping notification"
    return
  fi

  curl -s -X POST "$DISCORD_WEBHOOK" \
    -H "Content-Type: application/json" \
    -d "{\"content\": \"$message\"}" >/dev/null 2>&1 || true
}

# ---------------------------------------------------------------------------
# Session Detection (from pai-heartbeat)
# ---------------------------------------------------------------------------

has_active_session() {
  # Check for Claude Code processes
  if pgrep -f "claude" | grep -v "heartbeat\|launchd\|grep" &>/dev/null; then
    return 0
  fi

  # Check for other AI engines
  if pgrep -f "jay-gentic\|gemini-cli\|codex" &>/dev/null; then
    return 0
  fi

  return 1
}

# ---------------------------------------------------------------------------
# Core Execution
# ---------------------------------------------------------------------------

execute_item() {
  local item_id="$1"
  local title="$2"
  local effort="$3"
  local project="$4"

  log "INFO" "Executing: $item_id — $title (effort: $effort)"

  # Set timeout based on effort
  local item_timeout=$TIMEOUT_SECONDS
  case "$effort" in
    S) item_timeout=1800 ;;    # 30m
    M) item_timeout=3600 ;;    # 60m
    L) item_timeout=5400 ;;    # 90m
    XL) item_timeout=7200 ;;   # 120m
  esac

  # Mark as in_progress
  "$MANAGE_BACKLOG" update --id "$item_id" --status in_progress >/dev/null 2>&1 || true

  # Determine engine to use
  local engine="claude"
  if [[ -n "${PAI_USE_JAY_GENTIC:-}" ]] && command -v jay-gentic &>/dev/null; then
    engine="jay-gentic"
  fi

  log "INFO" "Using engine: $engine (timeout: ${item_timeout}s)"

  # Build execution context
  local prompt_file
  prompt_file=$(mktemp)
  cat > "$prompt_file" <<EOF
# Task: $title

## Context
- ID: $item_id
- Effort: $effort
- Project: $project

Execute this enhancement autonomously. When complete, indicate:
COMPLETED: <summary of what was accomplished>

Or if blocked:
BLOCKED: <reason blocking completion>

EOF

  # Execute with timeout
  local start_time
  start_time=$(date +%s)
  local result_file
  result_file=$(mktemp)
  local exit_code=0

  if [[ "$engine" == "jay-gentic" ]]; then
    timeout "$item_timeout" jay-gentic --agent sam --no-stream \
      --input-file "$prompt_file" > "$result_file" 2>&1 || exit_code=$?
  else
    timeout "$item_timeout" claude --print \
      --output-format stream-json \
      < "$prompt_file" > "$result_file" 2>&1 || exit_code=$?
  fi

  local end_time
  end_time=$(date +%s)
  local duration=$((end_time - start_time))

  # Parse result
  local result_status="skipped"
  local result_summary=""

  if [[ $exit_code -eq 124 ]]; then
    result_status="skipped"
    result_summary="Timeout after ${duration}s"
    log "WARN" "Item $item_id timed out after ${duration}s"
  elif [[ $exit_code -eq 0 ]] && [[ -s "$result_file" ]]; then
    # Check for completion markers
    if grep -q "COMPLETED:" "$result_file"; then
      result_status="completed"
      result_summary=$(grep "COMPLETED:" "$result_file" | head -1 | sed 's/COMPLETED: //')
      log "INFO" "Item $item_id completed: $result_summary"
    elif grep -q "BLOCKED:" "$result_file"; then
      result_status="skipped"
      result_summary=$(grep "BLOCKED:" "$result_file" | head -1 | sed 's/BLOCKED: //')
      log "WARN" "Item $item_id blocked: $result_summary"
    fi
  fi

  # Update backlog
  "$MANAGE_BACKLOG" update --id "$item_id" \
    --status "$result_status" \
    --result "$result_summary" >/dev/null 2>&1 || true

  # Post to Discord
  local discord_msg="✅ Executor: $item_id completed ($duration seconds)"
  if [[ "$result_status" != "completed" ]]; then
    discord_msg="⚠️ Executor: $item_id $result_status ($result_summary)"
  fi
  post_discord "$discord_msg"

  # Cleanup
  rm -f "$prompt_file" "$result_file"

  return 0
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  log "INFO" "=== Autonomous executor starting ==="

  # Guard: check for active session
  if has_active_session; then
    log "INFO" "Active session detected — aborting autonomous execution"
    exit 0
  fi

  log "INFO" "No active session — proceeding with execution"

  # Check manage-backlog
  if [[ ! -x "$MANAGE_BACKLOG" ]]; then
    log "ERROR" "manage-backlog.sh not found"
    exit 1
  fi

  # Get next approved item
  local next_item
  next_item=$("$MANAGE_BACKLOG" next --status approved 2>/dev/null || echo "")

  if [[ -z "$next_item" ]]; then
    log "INFO" "No approved items in backlog"
    exit 0
  fi

  # Parse item details
  local item_id title effort project
  item_id=$(echo "$next_item" | jq -r '.id' 2>/dev/null || echo "")
  title=$(echo "$next_item" | jq -r '.title' 2>/dev/null || echo "")
  effort=$(echo "$next_item" | jq -r '.effort' 2>/dev/null || echo "M")
  project=$(echo "$next_item" | jq -r '.metadata.project' 2>/dev/null || echo "unknown")

  if [[ -z "$item_id" ]]; then
    log "ERROR" "Could not parse backlog item"
    exit 1
  fi

  if [[ "$DRY_RUN" == "--dry-run" ]]; then
    log "INFO" "[DRY-RUN] Would execute: $item_id — $title"
    exit 0
  fi

  # Execute
  execute_item "$item_id" "$title" "$effort" "$project"

  log "INFO" "=== Autonomous executor complete ==="
}

main "$@"
