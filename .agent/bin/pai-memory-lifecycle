#!/usr/bin/env bash
#
# Memory System Lifecycle Manager
# Checks ENABLE_MEMORY_HOOKS flag before running maintenance operations
#
# Usage: pai-memory-lifecycle [operation]
#   nightly - Run nightly maintenance (full backup + consolidation)
#

set -euo pipefail

# Source environment
ENV_FILE="${PAI_DIR:=$HOME/.claude}/.env"
if [[ ! -f "$ENV_FILE" ]]; then
  echo "ERROR: $ENV_FILE not found"
  exit 1
fi
source "$ENV_FILE"

# Check if memory hooks are enabled
if [[ "${ENABLE_MEMORY_HOOKS:-false}" != "true" ]]; then
  echo "ℹ️  Memory hooks disabled (ENABLE_MEMORY_HOOKS=${ENABLE_MEMORY_HOOKS})"
  exit 0
fi

OPERATION="${1:-nightly}"
MEMORY_SYSTEM_DIR="$HOME/Projects/memory-system"

if [[ ! -f "$MEMORY_SYSTEM_DIR/scripts/backup-memory.sh" ]]; then
  echo "ERROR: Memory system scripts not found at $MEMORY_SYSTEM_DIR"
  exit 1
fi

case "$OPERATION" in
  nightly)
    echo "🧠 Running nightly memory lifecycle maintenance..."

    # Full backup for archival
    bash "$MEMORY_SYSTEM_DIR/scripts/backup-memory.sh" full

    # Attempt consolidation via memory-system API (if available)
    MEMORY_PORT="${MEMORY_HTTP_PORT:-4242}"
    if curl -s "http://localhost:$MEMORY_PORT/health" > /dev/null 2>&1; then
      echo "📊 Triggering memory consolidation..."
      curl -s -X POST "http://localhost:$MEMORY_PORT/memory/consolidation/run" > /dev/null 2>&1 || true
    fi

    echo "✅ Nightly lifecycle complete"
    ;;
  *)
    echo "ERROR: Unknown operation '$OPERATION'"
    echo "Supported operations: nightly"
    exit 1
    ;;
esac
